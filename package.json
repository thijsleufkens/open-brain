{
  "name": "open-brain",
  "version": "0.1.0",
  "description": "Self-hosted personal knowledge system with MCP interface",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "brain": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --env-file=.env --import=tsx src/mcp-http.ts",
    "dev:stdio": "node --env-file=.env --import=tsx src/mcp-stdio.ts",
    "start": "node --env-file=.env dist/mcp-http.js",
    "start:stdio": "node --env-file=.env dist/mcp-stdio.js",
    "brain": "node --env-file=.env --import=tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.7.0",
    "neverthrow": "^8.1.1",
    "pino": "^9.6.0",
    "grammy": "^1.35.0",
    "sqlite-vec": "^0.1.6",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
